# CourtAlert Configuration
# Copy this file to .env and fill in real values.

# System route protection. If empty, system routes are open.
COURTALERT_SYSTEM_API_KEY=

# Database path (defaults to courtalert.db in working directory)
DATABASE_URL=courtalert.db

# Bhashini credentials (pipeline discovery mode)
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_ID=

# Optional: direct compute mode (skip pipeline discovery)
BHASHINI_COMPUTE_URL=
BHASHINI_SERVICE_ID=
BHASHINI_INFERENCE_API_KEY=
BHASHINI_INFERENCE_API_HEADER=Authorization

# Optional runtime tuning
BHASHINI_SOURCE_LANGUAGE=en
BHASHINI_AUDIO_FORMAT=wav
BHASHINI_SAMPLING_RATE=16000
BHASHINI_TIMEOUT_SECONDS=30

# Twilio WhatsApp sender (use your approved Twilio WhatsApp number)
TWILIO_WHATSAPP_FROM=whatsapp:+14783128194
